[Unit]
Description=Mail Intelligence Search API
After=network.target

[Service]
Type=simple
User=wes
WorkingDirectory=/opt/ppd/apps/mail-search/backend
ExecStart=/home/wes/miniconda3/envs/py_latest/bin/uvicorn main:app --host 127.0.0.1 --port 8002
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
