FROM apache/airflow:2.10.2-python3.11

# Switch to root for OS deps (if needed)
USER root

# Optional: system deps needed for some libs (dbt / ML tools)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        libpq-dev \
        postgresql-client \
        graphviz \
        # add others if you hit build errors
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Wait-for-Postgres wrapper
COPY wait-for-db.sh /opt/airflow/wait-for-db.sh
RUN chmod +x /opt/airflow/wait-for-db.sh

# Back to airflow user
USER airflow

# Copy requirements for ML / dbt extras
COPY requirements-ml-dbt.txt /tmp/requirements-ml-dbt.txt

# Install extras with Airflow constraints to avoid dependency hell
# 1) Install Airflow with official constraints
RUN pip install "apache-airflow[celery,postgres,redis]==2.10.2" \
    --constraint "https://raw.githubusercontent.com/apache/airflow/constraints-2.10.2/constraints-3.11.txt"

# 2) Install dbt + ML tooling WITHOUT the Airflow constraint
COPY requirements-ml-dbt.txt /tmp/requirements-ml-dbt.txt
RUN pip install --no-cache-dir -r /tmp/requirements-ml-dbt.txt

# If you want, you can bake in DAGs/plugins, but most people mount them instead:
# COPY dags /opt/airflow/dags
# COPY plugins /opt/airflow/plugins

ENTRYPOINT ["/opt/airflow/wait-for-db.sh"]
